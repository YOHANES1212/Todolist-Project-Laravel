        </main>
    </div>

    <!-- LOGOUT MODAL -->
    <div id="logoutModal" class="modal">
        <div class="modal-content">
            <h2>Are You Sure?</h2>
            <p>You will be logged out of the current account.</p>
            <form method="POST" action="{{ route('logout') }}" class="modal-buttons">
                @csrf
                <button type="submit" class="modal-btn yes">Yes, Logout</button>
                <button type="button" onclick="hideLogoutModal()" class="modal-btn no">Cancel</button>
            </form>
        </div>
    </div>

    <script>
        function showLogoutModal() {
            const modal = document.getElementById('logoutModal');
            modal.style.display = 'flex';
            setTimeout(() => modal.classList.add('show'), 10);
        }

        function hideLogoutModal() {
            const modal = document.getElementById('logoutModal');
            modal.classList.remove('show');
            setTimeout(() => modal.style.display = 'none', 300);
        }

        // Close modal when clicking outside
        document.getElementById('logoutModal').addEventListener('click', function(e) {
            if (e.target === this) {
                hideLogoutModal();
            }
        });
    </script>
</body>
</html>
